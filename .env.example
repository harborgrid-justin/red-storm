# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DATABASE_URL="postgresql://evidence_user:evidence_pass@localhost:5432/evidence_platform?schema=public"
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30000

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# JWT Configuration
JWT_SECRET="your-super-secure-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secure-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Session Configuration
SESSION_SECRET="your-super-secure-session-secret-change-in-production"
SESSION_MAX_AGE=3600000

# Security Configuration
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN="http://localhost:3001"
CORS_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=info
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Service Discovery
CONSUL_HOST=localhost
CONSUL_PORT=8500

# External Services
SAML_ENTRY_POINT=""
SAML_ISSUER=""
SAML_CERT_PATH=""

# File Upload Configuration
MAX_FILE_SIZE=104857600
UPLOAD_PATH="./uploads"

# AWS/S3 Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# Email/SMTP Configuration
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# WebSocket Configuration
WEBSOCKET_CORS_ORIGIN="http://localhost:3001"